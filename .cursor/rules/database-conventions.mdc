# Database Conventions

## Schema Design Principles

- Use descriptive table and column names in English
- Include audit fields (createdAt, updatedAt) on all tables
- Use UUIDs for primary keys, proper data types and constraints
- Use `@@map()` to map Prisma names to snake_case database names

```prisma
model Trail {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @unique @db.VarChar(100)
  distance    Decimal  @db.Decimal(8, 2) // km with 2 decimal places
  elevation   Int?     // meters
  difficulty  TrailDifficulty
  location    String   @db.VarChar(200)
  coordinates Json?    // { lat: number, lng: number }
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  races       Race[]
  userTrails  UserTrail[]

  @@index([difficulty])
  @@index([location])
  @@index([isActive])
  @@map("trails")
}

model Race {
  id          String     @id @default(uuid()) @db.Uuid
  name        String     @db.VarChar(150)
  trailId     String     @db.Uuid
  date        DateTime
  startTime   DateTime
  maxRunners  Int?
  price       Decimal?   @db.Decimal(10, 2)
  status      RaceStatus @default(próximo)
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  trail       Trail      @relation(fields: [trailId], references: [id])
  registrations RaceRegistration[]

  @@index([trailId])
  @@index([date])
  @@index([status])
  @@index([date, status]) // Composite index
  @@map("races")
}
```

## Enum Definitions

- Keep enum names in English for code consistency
- Use `@@map()` for snake_case database names

```prisma
enum TrailDifficulty {
  fácil
  moderado
  difícil
  experto
  @@map("trail_difficulty")
}

enum RaceStatus {
  próximo
  en_curso
  completado
  cancelado
  pospuesto
  @@map("race_status")
}
```

## Relationship Patterns

- Use explicit foreign keys with proper cascade behaviors
- Use junction tables for many-to-many relationships
- Include indexes on foreign keys and frequently queried columns

```prisma
model RaceRegistration {
  id         String             @id @default(uuid()) @db.Uuid
  userId     String             @db.Uuid
  raceId     String             @db.Uuid
  status     RegistrationStatus @default(pendiente)
  registeredAt DateTime         @default(now())

  user       User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  race       Race               @relation(fields: [raceId], references: [id], onDelete: Cascade)

  @@unique([userId, raceId])
  @@index([userId])
  @@index([raceId])
  @@index([status])
  @@map("race_registrations")
}
```

## Migration Best Practices

- Use descriptive migration names with timestamps
- Use transactions for complex migrations
- Test migrations on development data first

```sql
-- Migration: 20241201_000001_add_trail_coordinates.sql
BEGIN;

ALTER TABLE trails ADD COLUMN coordinates JSONB;
CREATE INDEX idx_trails_coordinates ON trails USING GIN (coordinates);

UPDATE trails SET coordinates = '{"lat": 0, "lng": 0}' WHERE coordinates IS NULL;

COMMIT;
```

## Query Optimization

- Use proper WHERE clauses and pagination
- Select specific columns instead of SELECT \*
- Leverage database indexes effectively

```typescript
// repositories/trail.repository.ts
export const findTrailsWithPagination = async (
  filters: TrailFilters,
  page: number = 1,
  limit: number = 20,
): Promise<{ trails: Trail[]; total: number }> => {
  const skip = (page - 1) * limit;

  const [trails, total] = await Promise.all([
    prisma.trail.findMany({
      where: {
        isActive: true,
        ...(filters.difficulty && { difficulty: filters.difficulty }),
        ...(filters.location && {
          location: { contains: filters.location, mode: 'insensitive' },
        }),
      },
      select: {
        id: true,
        name: true,
        distance: true,
        difficulty: true,
        location: true,
        elevation: true,
      },
      orderBy: { createdAt: 'desc' },
      skip,
      take: limit,
    }),
    prisma.trail.count({ where: { isActive: true } }),
  ]);

  return { trails, total };
};
```

## Data Seeding

- Create realistic seed data for development and testing
- Include edge cases and boundary conditions

```typescript
// prisma/seed.ts
import { PrismaClient } from '@prisma/client';

const prisma = new PrismaClient();

async function main() {
  const trail = await prisma.trail.create({
    data: {
      name: 'Sendero de la Montaña',
      distance: 12.5,
      elevation: 850,
      difficulty: 'moderado',
      location: 'Parque Nacional Sierra Nevada',
      coordinates: { lat: 37.0902, lng: -3.5892 },
    },
  });

  await prisma.race.create({
    data: {
      name: 'Carrera de Montaña 2024',
      trailId: trail.id,
      date: new Date('2024-06-15'),
      startTime: new Date('2024-06-15T08:00:00Z'),
      maxRunners: 100,
      price: 25.0,
      status: 'próximo',
    },
  });
}

main()
  .catch(console.error)
  .finally(() => prisma.$disconnect());
```

## Environment Configuration

- Use environment variables for database connection
- Separate configurations for different environments
- Use connection pooling for production

```typescript
// config/database.config.ts
export const databaseConfig = {
  development: {
    url:
      process.env.DATABASE_URL_DEV ||
      'postgresql://user:password@localhost:5432/trailrunning_dev',
    pool: { min: 2, max: 10 },
  },
  production: {
    url: process.env.DATABASE_URL,
    pool: { min: 5, max: 20 },
    ssl: { rejectUnauthorized: false },
  },
  test: {
    url:
      process.env.DATABASE_URL_TEST ||
      'postgresql://user:password@localhost:5432/trailrunning_test',
    pool: { min: 1, max: 5 },
  },
};
```

## Performance Monitoring

- Monitor query performance and slow queries
- Implement proper logging for database operations

```typescript
// utils/database-monitoring.ts
import { PrismaClient } from '@prisma/client';

const prisma = new PrismaClient({
  log: [
    { emit: 'event', level: 'query' },
    { emit: 'event', level: 'error' },
  ],
});

prisma.$on('query', (e) => {
  if (e.duration > 1000) {
    console.warn(`Slow query: ${e.duration}ms - ${e.query}`);
  }
});

export { prisma };
```

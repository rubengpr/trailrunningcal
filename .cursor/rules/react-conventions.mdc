# React Conventions

## Component Structure

- Use functional components with hooks, TypeScript interfaces for props

Examples:

```typescript
import React, { useState, useEffect } from 'react';
import { Trail } from '../types/trail.types';

interface TrailCardProps {
  trail: Trail;
  onTrailSelect: (trailId: string) => void;
  showDistance?: boolean;
}

export default function TrailCard({
  trail,
  onTrailSelect,
  showDistance = true,
}: TrailCardProps) {
  const [isLoading, setIsLoading] = useState(false);

  useEffect(() => {
    // Component initialization logic
  }, []);

  return (
    <div className="bg-white rounded-lg shadow-md p-4 hover:shadow-lg transition-shadow">
      {/* Component JSX */}
    </div>
  );
}
```

## State Management

- Use useState for local state, useReducer for complex logic, lift state up when needed

Examples:

```typescript
const [trailData, setTrailData] = useState<Trail | null>(null);
const [isLoading, setIsLoading] = useState(false);
const [error, setError] = useState<string>('');

interface TrailState {
  trails: Trail[];
  selectedTrail: Trail | null;
  filters: TrailFilters;
  isLoading: boolean;
}

const [trailState, dispatch] = useReducer(trailReducer, initialState);

const useTrailData = (trailId: string) => {
  const [trail, setTrail] = useState<Trail | null>(null);
  const [isLoading, setIsLoading] = useState(false);

  useEffect(() => {
    fetchTrailData(trailId).then(setTrail);
  }, [trailId]);

  return { trail, isLoading };
};
```

## Event Handling

- Use handle prefix for internal handlers, on prefix for props

Examples:

```typescript
const handleTrailClick = (trailId: string) => {
  setSelectedTrail(trailId);
  onTrailSelect(trailId);
};

const handleFormSubmit = async (event: FormEvent) => {
  event.preventDefault();
  setIsLoading(true);

  try {
    await submitTrailForm(formData);
  } catch (error) {
    setError('Failed to submit trail');
  } finally {
    setIsLoading(false);
  }
};

interface TrailListProps {
  onTrailSelect: (trailId: string) => void;
  onTrailDelete: (trailId: string) => void;
}
```

## Optimization Patterns

- Use React.memo, useMemo, useCallback for performance
- Create custom hooks for reusable logic
- Keep hooks focused on single responsibilities

Examples:

```typescript
const TrailCard = React.memo(({ trail, onSelect }: TrailCardProps) => (
  <div onClick={() => onSelect(trail.id)}>{trail.name}</div>
));

const TrailStats = ({ trails }: { trails: Trail[] }) => {
  const totalDistance = useMemo(
    () => trails.reduce((sum, trail) => sum + trail.distance, 0),
    [trails],
  );

  return <div>Total: {totalDistance}km</div>;
};

const TrailList = ({ trails }: { trails: Trail[] }) => {
  const handleSelect = useCallback((trailId: string) => {
    // Handle selection logic
  }, []);

  return (
    <div>
      {trails.map((trail) => (
        <TrailCard key={trail.id} trail={trail} onSelect={handleSelect} />
      ))}
    </div>
  );
};

const useTrailData = (trailId: string) => {
  const [trail, setTrail] = useState<Trail | null>(null);
  const [isLoading, setIsLoading] = useState(false);
  const [error, setError] = useState<Error | null>(null);

  useEffect(() => {
    const fetchTrail = async () => {
      setIsLoading(true);
      try {
        const trailData = await TrailService.getTrail(trailId);
        setTrail(trailData);
      } catch (err) {
        setError(err as Error);
      } finally {
        setIsLoading(false);
      }
    };

    if (trailId) fetchTrail();
  }, [trailId]);

  return { trail, isLoading, error };
};
```

## Component Composition

- Use composition over inheritance, create reusable UI components

Examples:

```typescript
const Button = ({
  children,
  variant = 'primary',
  onClick,
  disabled = false,
}: ButtonProps) => {
  const baseClasses = 'px-4 py-2 rounded-lg font-medium transition-colors';
  const variantClasses = {
    primary: 'bg-blue-600 text-white hover:bg-blue-700',
    secondary: 'bg-gray-200 text-gray-900 hover:bg-gray-300',
    danger: 'bg-red-600 text-white hover:bg-red-700',
  };

  return (
    <button
      className={`${baseClasses} ${variantClasses[variant]} ${
        disabled ? 'opacity-50 cursor-not-allowed' : ''
      }`}
      onClick={onClick}
      disabled={disabled}
    >
      {children}
    </button>
  );
};

const TrailContainer = ({ children, title }: TrailContainerProps) => (
  <div className="max-w-7xl mx-auto px-4">
    <h2 className="text-2xl font-bold mb-6">{title}</h2>
    <div className="space-y-6">{children}</div>
  </div>
);
```

## Async Operations

- Use try/catch for async operations, useState for error/loading state
- Use skeleton components for loading states
- Create reusable ErrorMessage components

Examples:

```typescript
const TrailProfile = () => {
  const [trail, setTrail] = useState<Trail | null>(null);
  const [error, setError] = useState<Error | null>(null);
  const [isLoading, setIsLoading] = useState(true);

  useEffect(() => {
    const fetchTrail = async () => {
      try {
        setIsLoading(true);
        const trailData = await TrailService.getTrail(trailId);
        setTrail(trailData);
      } catch (fetchError) {
        setError(fetchError as Error);
      } finally {
        setIsLoading(false);
      }
    };

    fetchTrail();
  }, [trailId]);

  if (error) return <ErrorMessage error={error} />;
  if (isLoading) return <TrailSkeleton />;

  return <TrailView trail={trail} />;
};

const TrailListSkeleton = () => (
  <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
    {Array.from({ length: 6 }).map((_, index) => (
      <div
        key={index}
        className="bg-white rounded-lg shadow-md p-4 animate-pulse"
      >
        <div className="h-48 bg-gray-200 rounded-lg mb-4" />
        <div className="space-y-3">
          <div className="h-4 bg-gray-200 rounded w-3/4" />
          <div className="h-4 bg-gray-200 rounded w-1/2" />
        </div>
      </div>
    ))}
  </div>
);
```

## Global State Management

- Use Zustand for global state, create typed stores with actions

Examples:

```typescript
interface TrailStore {
  selectedTrail: Trail | null;
  favoriteTrails: Trail[];
  setSelectedTrail: (trail: Trail | null) => void;
  addToFavorites: (trail: Trail) => void;
  removeFromFavorites: (trailId: string) => void;
}

export const useTrailStore = create<TrailStore>((set) => ({
  selectedTrail: null,
  favoriteTrails: [],
  setSelectedTrail: (trail) => set({ selectedTrail: trail }),
  addToFavorites: (trail) =>
    set((state) => ({
      favoriteTrails: [...state.favoriteTrails, trail],
    })),
  removeFromFavorites: (trailId) =>
    set((state) => ({
      favoriteTrails: state.favoriteTrails.filter(
        (trail) => trail.id !== trailId,
      ),
    })),
}));

const TrailCard = ({ trail }: TrailCardProps) => {
  const { setSelectedTrail, addToFavorites } = useTrailStore();
  const handleSelect = () => setSelectedTrail(trail);
  const handleFavorite = () => addToFavorites(trail);
  return <div>{/* Component content */}</div>;
};
```


# API Conventions

## REST API Structure

- Use standard REST endpoints with clear resource naming
- Follow HTTP status codes and methods consistently
- Keep endpoints simple and predictable

```typescript
// routes/trails.routes.ts
import { Router } from 'express';
import {
  getAllTrails,
  getTrailById,
  createTrail,
  updateTrail,
  deleteTrail,
} from '../controllers/trail.controller';

const router = Router();

router.get('/', getAllTrails);
router.get('/:id', getTrailById);
router.post('/', createTrail);
router.put('/:id', updateTrail);
router.delete('/:id', deleteTrail);

export default router;
```

## Controller Patterns

- Keep controllers thin - delegate business logic to services
- Use proper error handling and status codes
- Validate input data before processing

```typescript
// controllers/trail.controller.ts
import { Request, Response } from 'express';
import { getAllTrails as getAllTrailsService } from '../services/trail.service';
import { handleError } from '../utils/error.util';

export const getAllTrails = async (req: Request, res: Response) => {
  try {
    const { page = 1, limit = 20, difficulty } = req.query;
    const trails = await getAllTrailsService({
      page: Number(page),
      limit: Number(limit),
      difficulty: difficulty as string,
    });

    res.status(200).json({ success: true, data: trails });
  } catch (error) {
    const { message, statusCode } = handleError(error);
    res.status(statusCode).json({ message });
  }
};

export const getTrailById = async (req: Request, res: Response) => {
  try {
    const { id } = req.params;
    const trail = await getTrailByIdService(id);

    if (!trail) {
      res.status(404).json({ message: 'Sendero no encontrado' });
      return;
    }

    res.status(200).json({ success: true, data: trail });
  } catch (error) {
    const { message, statusCode } = handleError(error);
    res.status(statusCode).json({ message });
  }
};
```

## Service Layer

- Handle business logic and database operations
- Use dependency injection for testability
- Keep services focused on single responsibilities

```typescript
// services/trail.service.ts
import { findAll, findByName, create } from '../repositories/trail.repository';
import type { Trail, TrailWithoutId, TrailFilters } from '../types/trail.types';

export const createTrail = async (data: TrailWithoutId): Promise<Trail> => {
  const { name, distance, difficulty, location } = data;

  if (!name || !distance || !difficulty || !location) {
    throw { message: 'Faltan campos requeridos', statusCode: 400 };
  }

  if (name.length < 1 || name.length > 100) {
    throw {
      message: 'El nombre del sendero debe tener entre 1 y 100 caracteres',
      statusCode: 400,
    };
  }

  if (distance <= 0 || distance > 1000) {
    throw {
      message: 'La distancia debe estar entre 0.1 y 1000 km',
      statusCode: 400,
    };
  }

  const allowedDifficulties = ['fácil', 'moderado', 'difícil', 'experto'];
  if (!allowedDifficulties.includes(difficulty)) {
    throw { message: 'Dificultad no válida', statusCode: 400 };
  }

  const existingTrail = await findByName(name);
  if (existingTrail) {
    throw { message: 'Ya existe un sendero con este nombre', statusCode: 409 };
  }

  try {
    return await create(data);
  } catch (error) {
    throw { message: 'Error al crear sendero', statusCode: 500 };
  }
};
```

## Database Repository Pattern with Prisma

- Use Prisma ORM for type-safe database operations
- Keep repository pattern for business logic separation
- Handle Prisma errors gracefully

```typescript
// repositories/trail.repository.ts
import { PrismaClient } from '@prisma/client';
import type { Trail, TrailWithoutId, TrailFilters } from '../types/trail.types';

const prisma = new PrismaClient();

const mapPrismaToTrail = (prismaTrail: any): Trail => ({
  id: prismaTrail.id,
  name: prismaTrail.name,
  distance: prismaTrail.distance,
  difficulty: prismaTrail.difficulty,
  location: prismaTrail.location,
  createdAt: prismaTrail.createdAt,
  updatedAt: prismaTrail.updatedAt,
});

export const findAll = async (filters: TrailFilters): Promise<Trail[]> => {
  const { page = 1, limit = 20, difficulty } = filters;
  const skip = (page - 1) * limit;

  const trails = await prisma.trail.findMany({
    where: difficulty ? { difficulty } : undefined,
    orderBy: { createdAt: 'desc' },
    skip,
    take: limit,
  });

  return trails.map(mapPrismaToTrail);
};

export const findById = async (id: string): Promise<Trail | null> => {
  const trail = await prisma.trail.findUnique({ where: { id } });
  return trail ? mapPrismaToTrail(trail) : null;
};

export const create = async (trailData: TrailWithoutId): Promise<Trail> => {
  const trail = await prisma.trail.create({ data: trailData });
  return mapPrismaToTrail(trail);
};
```

## Error Handling

- Create custom error classes for different scenarios
- Use centralized error handling for consistency

```typescript
// utils/error.util.ts
export const handleError = (
  error: unknown,
): { message: string; statusCode: number } => {
  if (
    typeof error === 'object' &&
    error !== null &&
    'message' in error &&
    'statusCode' in error
  ) {
    return {
      message: String(error.message),
      statusCode: Number(error.statusCode),
    };
  }

  return {
    message: error instanceof Error ? error.message : 'Something went wrong',
    statusCode: 500,
  };
};
```

## Middleware Patterns

- Use middleware for common functionality
- Keep middleware focused and reusable
- Handle errors in middleware

```typescript
// middleware/validation.middleware.ts
import { Request, Response, NextFunction } from 'express';

export const validateTrailData = (
  req: Request,
  res: Response,
  next: NextFunction,
): void => {
  const { name, distance, difficulty } = req.body;

  if (!name || name.trim().length === 0) {
    throw new ValidationError('El nombre del sendero es requerido', 'name');
  }

  if (!distance || distance <= 0) {
    throw new ValidationError('La distancia debe ser mayor a 0', 'distance');
  }

  if (
    !difficulty ||
    !['fácil', 'moderado', 'difícil', 'experto'].includes(difficulty)
  ) {
    throw new ValidationError('Dificultad inválida', 'difficulty');
  }

  next();
};

// middleware/error.middleware.ts
export const errorHandler = (
  error: unknown,
  req: Request,
  res: Response,
  next: NextFunction,
): void => {
  if (
    typeof error === 'object' &&
    error !== null &&
    'message' in error &&
    'statusCode' in error
  ) {
    res.status(Number(error.statusCode)).json({
      message: String(error.message),
    });
  } else {
    console.error('Unexpected error:', error);
    res.status(500).json({
      message: 'Internal server error',
    });
  }
};
```

## API Response Format

- Use consistent response structure
- Include success status and data
- Provide meaningful error messages

```typescript
// types/api.types.ts
export interface ApiResponse<T> {
  success: boolean;
  data?: T;
  message?: string;
  code?: string;
  pagination?: {
    page: number;
    limit: number;
    total: number;
  };
}

// utils/response.util.ts
export const createSuccessResponse = <T>(
  data: T,
  message?: string,
): ApiResponse<T> => ({
  success: true,
  data,
  message,
});

export const createErrorResponse = (
  message: string,
  code?: string,
): ApiResponse<null> => ({
  success: false,
  message,
  code,
});
```

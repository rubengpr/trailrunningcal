# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# Skills eval workspaces
.claude/skills/*-workspace/

# dependencies
/node_modules
.pnpm-store/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# Claude Code local worktrees (not part of this repo)
.claude/worktrees/

# geocode script cache (Nominatim — do not commit)
scripts/.cache/

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Local sponsor mockups — never commit or deploy prospect assets
/public/assets/sponsors/previews/

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
